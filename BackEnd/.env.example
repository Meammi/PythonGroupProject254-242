APP_NAME=Clean FastAPI Backend
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clean_fastapi

# CORS — comma-separated list of allowed frontend origins.
# Leave empty or omit to default to wildcard (*).
ALLOWED_ORIGINS=http://localhost:5173,https://tulong.app,https://www.tulong.app
